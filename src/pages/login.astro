---
import { LockKeyhole, LogIn, ShieldCheck } from '@lucide/astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
---

<BaseLayout title="Acceso institucional | Buzón CETis No. 26" shell="app">
  <div class="mx-auto grid max-w-5xl gap-8 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-start">
    <div>
      <PageHeader
        eyebrow="Acceso institucional"
        title="Panel de revisión"
        description="Ingresa con una cuenta autorizada para consultar reportes, revisar sugerencias y dar seguimiento a los casos registrados."
      />
      <form id="login-form" class="apple-surface grid gap-5 p-5 sm:p-7" novalidate>
        <div class="rounded-2xl border border-zinc-200/80 bg-white p-4 sm:p-5">
          <div class="mb-5 flex items-center gap-3">
            <span class="grid h-10 w-10 place-items-center rounded-xl bg-rosewood/10">
              <LockKeyhole class="h-5 w-5 text-rosewood" />
            </span>
            <div>
              <h2 class="font-semibold text-ink">Credenciales autorizadas</h2>
              <p class="text-sm text-zinc-500">Acceso exclusivo para personal autorizado.</p>
            </div>
          </div>

          <div class="grid gap-5">
            <div class="grid gap-2">
              <label class="field-label" for="email">Correo</label>
              <input id="email" name="email" class="input" type="email" autocomplete="email" required placeholder="correo@institucion.edu" />
              <p id="login-email-error" class="field-error hidden"></p>
            </div>
            <div class="grid gap-2">
              <label class="field-label" for="password">Contraseña</label>
              <input id="password" name="password" class="input" type="password" autocomplete="current-password" required placeholder="Contraseña" />
              <p id="login-password-error" class="field-error hidden"></p>
            </div>
          </div>
        </div>

        <div id="login-error" class="hidden rounded-md border border-red-200 bg-red-50 p-3 text-sm text-red-700"></div>
        <button class="btn-primary w-full sm:w-auto sm:justify-self-start" type="submit" data-submit-label="Entrar al panel" data-loading-label="Verificando...">
          <LogIn class="h-4 w-4" />
          <span>Entrar al panel</span>
        </button>
      </form>
    </div>

    <aside class="apple-surface p-6">
      <div class="flex items-start gap-3">
        <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-rosewood/10">
          <ShieldCheck class="h-5 w-5 text-rosewood" />
        </span>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-rosewood">Control interno</p>
          <h2 class="mt-2 text-2xl font-semibold text-ink">Seguridad y trazabilidad</h2>
        </div>
      </div>
      <p class="mt-5 text-sm leading-7 text-zinc-600">
        Las acciones dentro del panel quedan registradas para mantener seguimiento responsable.
      </p>
      <div class="mt-6 grid gap-3 text-sm text-zinc-600">
        <div class="rounded-xl border border-zinc-200/80 bg-white p-4">Consulta de reportes registrados.</div>
        <div class="rounded-xl border border-zinc-200/80 bg-white p-4">Revisión de sugerencias y quejas.</div>
        <div class="rounded-xl border border-zinc-200/80 bg-white p-4">Seguimiento por personal autorizado.</div>
      </div>
    </aside>
  </div>
  <script>
    import '@/scripts/login';
  </script>
</BaseLayout>
