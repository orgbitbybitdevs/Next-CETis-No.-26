---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import ReportForm from '@/components/ReportForm.astro';
---

<BaseLayout title="Enviar queja | Buzón CETis No. 26" shell="app">
  <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_21rem] lg:items-start">
    <div>
      <PageHeader
        eyebrow="Reporte"
        title="Presentar queja"
        description="Comparte una situación que requiere atención institucional. Puedes adjuntar una imagen como evidencia; permanecerá oculta hasta que el personal autorizado la revise."
      />
      <ReportForm type="complaint" />
    </div>

    <aside class="apple-surface sticky top-24 hidden p-6 lg:block">
      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-rosewood">Orientación</p>
      <h2 class="mt-3 text-2xl font-semibold text-ink">Para una mejor revisión</h2>
      <div class="mt-6 grid gap-5">
        <div class="grid grid-cols-[2rem_1fr] gap-3">
          <span class="font-mono text-sm font-semibold text-rosewood">01</span>
          <div>
            <h3 class="font-semibold text-ink">Describe el caso con claridad</h3>
            <p class="mt-1 text-sm leading-6 text-zinc-600">Indica qué ocurrió, dónde y cuándo.</p>
          </div>
        </div>
        <div class="grid grid-cols-[2rem_1fr] gap-3">
          <span class="font-mono text-sm font-semibold text-rosewood">02</span>
          <div>
            <h3 class="font-semibold text-ink">Evita datos sensibles</h3>
            <p class="mt-1 text-sm leading-6 text-zinc-600">No incluyas información personal de terceros si no es necesaria.</p>
          </div>
        </div>
        <div class="grid grid-cols-[2rem_1fr] gap-3">
          <span class="font-mono text-sm font-semibold text-rosewood">03</span>
          <div>
            <h3 class="font-semibold text-ink">Evidencia bajo revisión</h3>
            <p class="mt-1 text-sm leading-6 text-zinc-600">Las imágenes se mantienen ocultas hasta ser revisadas.</p>
          </div>
        </div>
      </div>
    </aside>
  </div>
  <script>
    import '@/scripts/submitReport';
  </script>
</BaseLayout>
