---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import ReportForm from '@/components/ReportForm.astro';
---

<BaseLayout title="Enviar sugerencia | Buzón CETis No. 26" shell="app">
  <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_21rem] lg:items-start">
    <div>
      <PageHeader
        eyebrow="Propuesta"
        title="Enviar sugerencia"
        description="Propón una mejora para el plantel. Las sugerencias no aceptan imágenes para mantener el proceso ligero, privado y enfocado."
      />
      <ReportForm type="suggestion" />
    </div>

    <aside class="apple-surface sticky top-24 hidden p-6 lg:block">
      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-rosewood">Orientación</p>
      <h2 class="mt-3 text-2xl font-semibold text-ink">Cómo crear una buena sugerencia</h2>
      <div class="mt-6 grid gap-5">
        <div class="grid grid-cols-[2rem_1fr] gap-3">
          <span class="font-mono text-sm font-semibold text-rosewood">01</span>
          <div>
            <h3 class="font-semibold text-ink">Explica la mejora</h3>
            <p class="mt-1 text-sm leading-6 text-zinc-600">Describe qué cambio propones.</p>
          </div>
        </div>
        <div class="grid grid-cols-[2rem_1fr] gap-3">
          <span class="font-mono text-sm font-semibold text-rosewood">02</span>
          <div>
            <h3 class="font-semibold text-ink">Menciona el beneficio</h3>
            <p class="mt-1 text-sm leading-6 text-zinc-600">Indica cómo ayudaría al plantel o a los estudiantes.</p>
          </div>
        </div>
        <div class="grid grid-cols-[2rem_1fr] gap-3">
          <span class="font-mono text-sm font-semibold text-rosewood">03</span>
          <div>
            <h3 class="font-semibold text-ink">Mantén el enfoque</h3>
            <p class="mt-1 text-sm leading-6 text-zinc-600">Evita datos personales o información innecesaria.</p>
          </div>
        </div>
      </div>
    </aside>
  </div>
  <script>
    import '@/scripts/submitReport';
  </script>
</BaseLayout>
